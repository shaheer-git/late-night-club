# Backend
DATABASE_URL=postgresql://lnc_user:lnc_pass@localhost:5432/latenightclub
REDIS_URL=redis://localhost:6379
SECRET_KEY=your-secret-key-minimum-32-chars-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
ENVIRONMENT=development

# Firebase (optional — for push notifications)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Cloudflare R2 (optional — legacy)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=latenightclub-media
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# WhatsApp Gateway
WHATSAPP_GATEWAY_URL=http://localhost:3000

# Frontend
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_APP_NAME=Late Night Club

