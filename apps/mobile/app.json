{
  "expo": {
    "name": "Late Night Club",
    "slug": "late-night-club",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "lnc",
    "userInterfaceStyle": "dark",
    "assetBundlePatterns": ["**/*"],
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2C2C2C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lnc.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#2C2C2C"
      },
      "package": "com.lnc.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Late Night Club to use your location to show nearby open places."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Late Night Club to access your photos to upload place images."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
